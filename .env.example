# =======================================================
# TrustPULSE X — Complete MERN Environment Variables
# =======================================================

# Server Environment Settings
NODE_ENV=development
PORT=5000

# Database Configuration
# Local mongodb uri (without Docker):
MONGODB_URI=mongodb://localhost:27017/trustpulse
# When running with Docker Compose:
# MONGODB_URI=mongodb://mongodb:27017/trustpulse

# Security & Session Authentication
# Must be secure keys in production (minimum 32 characters)
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_key_change_in_production_min_32_chars
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# Client Configurations
CLIENT_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:5000

# Third-Party API OAuth Keys (Optional)
# Google Credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# GitHub Credentials
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Email Verification (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=noreply@trustpulse.ai

# OpenAI AI Summaries & Chatbot Capabilities (Optional)
# Falls back to mock NLP models if key is absent
OPENAI_API_KEY=sk-your_openai_key

# Finnhub API Key for real-time company fetching
FINNHUB_API_KEY=d881qipr01qmhakhrccgd881qipr01qmhakhrcd0

